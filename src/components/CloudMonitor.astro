---
const servers = [
	{ id: "hk-01", name: "HK-01" },
	{ id: "hk-02", name: "HK-02" },
	{ id: "us-01", name: "US-01" },
];
---

<div class="hud-monitor" data-cloud-monitor>
	<div class="monitor-frame">
		<div class="monitor-radar" aria-hidden="true">
			<span class="radar-ring radar-outer"></span>
			<span class="radar-ring radar-inner"></span>
			<span class="radar-axis radar-axis-h"></span>
			<span class="radar-axis radar-axis-v"></span>
			{servers.map((server) => (
				<span class={`radar-point point-${server.id}`} data-radar-point={server.id}></span>
			))}
		</div>

		<div class="monitor-summary">
			<div class="monitor-head">
				<span class="monitor-label">[SYS.MONITOR]</span>
				<span class="monitor-overall" data-monitor-overall-label>BOOTING</span>
			</div>
			<div class="monitor-subline">EDGE_NODES / TEXT_FEED / NO_PANEL</div>
		</div>
	</div>

	<div class="monitor-rows">
		{servers.map((server) => (
			<div class="m-row" data-server-id={server.id} data-state="idle">
				<span class="m-name">[{server.name}]</span>
				<span class="m-state" data-server-state-label>SYS:--</span>
				<span class="m-metric">C:<span data-metric-value="cpu">--</span></span>
				<span class="m-metric">M:<span data-metric-value="memory">--</span></span>
			</div>
		))}
	</div>
</div>

<script is:inline>
	const monitorRoot = document.querySelector("[data-cloud-monitor]");
	const overallLabel = monitorRoot?.querySelector("[data-monitor-overall-label]");
	const rows = new Map(
		Array.from(monitorRoot?.querySelectorAll("[data-server-id]") ?? []).map((row) => [
			row.getAttribute("data-server-id"),
			row,
		]),
	);
	const radarPoints = new Map(
		Array.from(monitorRoot?.querySelectorAll("[data-radar-point]") ?? []).map((point) => [
			point.getAttribute("data-radar-point"),
			point,
		]),
	);

	const metricKeys = ["cpu", "memory"];
	let nextPollTimer = null;

	const formatPercent = (value) => `${Math.round(value)}%`;

	const setOverallState = (label) => {
		if (overallLabel) overallLabel.textContent = label;
	};

	const setVisualState = (serverId, state) => {
		const row = rows.get(serverId);
		const point = radarPoints.get(serverId);
		if (row) row.dataset.state = state;
		if (point) point.dataset.state = state;
	};

	const setRowOffline = (row, message = "SYS:ERR") => {
		const serverId = row.getAttribute("data-server-id");
		const stateLabel = row.querySelector("[data-server-state-label]");
		if (stateLabel) stateLabel.textContent = message;

		for (const metricKey of metricKeys) {
			const valueNode = row.querySelector(`[data-metric-value="${metricKey}"]`);
			if (valueNode) valueNode.textContent = "--";
		}

		if (serverId) setVisualState(serverId, "offline");
	};

	const updateRow = (server) => {
		const row = rows.get(server.id);
		if (!row) return;

		const isOnline = server.status === "online";
		const stateLabel = row.querySelector("[data-server-state-label]");
		if (stateLabel) stateLabel.textContent = isOnline ? "SYS:OK" : "SYS:ERR";

		for (const metricKey of metricKeys) {
			const metricValue = Number(server.metrics?.[metricKey] ?? 0);
			const safeValue = Number.isFinite(metricValue) ? Math.max(0, Math.min(100, metricValue)) : 0;
			const valueNode = row.querySelector(`[data-metric-value="${metricKey}"]`);
			if (valueNode) valueNode.textContent = isOnline ? formatPercent(safeValue) : "--";
		}

		setVisualState(server.id, isOnline ? "online" : "offline");
	};

	const scheduleNextPoll = (intervalSeconds = 15) => {
		window.clearTimeout(nextPollTimer);
		nextPollTimer = window.setTimeout(fetchStatus, Math.max(5, intervalSeconds) * 1000);
	};

	async function fetchStatus() {
		setOverallState("FETCHING");

		try {
			const response = await fetch("/api/server-status", {
				headers: { Accept: "application/json" },
				cache: "no-store",
			});
			if (!response.ok) {
				throw new Error(`Unexpected status: ${response.status}`);
			}

			const payload = await response.json();
			const responseServers = Array.isArray(payload.servers) ? payload.servers : [];
			const onlineCount = responseServers.filter((server) => server.status === "online").length;
			const totalCount = responseServers.length || rows.size;

			for (const server of responseServers) {
				updateRow(server);
			}

			for (const [serverId, row] of rows.entries()) {
				if (!responseServers.some((server) => server.id === serverId)) {
					setRowOffline(row);
				}
			}

			setOverallState(onlineCount === totalCount ? "ALL_GREEN" : `WARN_${onlineCount}/${totalCount}`);
			scheduleNextPoll(payload.refreshIntervalSeconds ?? 15);
		} catch (error) {
			console.error("Failed to load server status", error);
			setOverallState("LINK_LOST");
			for (const [, row] of rows.entries()) {
				setRowOffline(row, "SYS:DOWN");
			}
			scheduleNextPoll(15);
		}
	}

	if (monitorRoot) {
		for (const server of rows.keys()) {
			setVisualState(server, "idle");
		}
		fetchStatus();
	}
</script>

<style>
	.hud-monitor {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		font-size: 0.72rem;
		color: var(--hud-ink);
	}

	.monitor-frame {
		display: grid;
		grid-template-columns: auto 1fr;
		gap: 1rem;
		align-items: start;
		padding-bottom: 0.9rem;
		border-bottom: 1px solid var(--hud-line);
	}

	.monitor-radar {
		position: relative;
		width: 5.75rem;
		height: 5.75rem;
		flex-shrink: 0;
	}

	.radar-ring,
	.radar-axis,
	.radar-point {
		position: absolute;
		display: block;
	}

	.radar-ring {
		border: 1px solid var(--hud-line);
	}

	.radar-outer {
		inset: 0;
	}

	.radar-inner {
		inset: 1.1rem;
	}

	.radar-axis-h {
		top: 50%;
		left: 0;
		width: 100%;
		height: 1px;
		background: var(--hud-line);
		transform: translateY(-50%);
	}

	.radar-axis-v {
		top: 0;
		left: 50%;
		width: 1px;
		height: 100%;
		background: var(--hud-line);
		transform: translateX(-50%);
	}

	.radar-point {
		width: 0.38rem;
		height: 0.38rem;
		border: 1px solid var(--hud-line-strong);
		background: transparent;
		opacity: 0.48;
		transition: opacity 0.18s ease, border-color 0.18s ease;
	}

	.point-hk-01 {
		top: 24%;
		left: 68%;
	}

	.point-hk-02 {
		top: 40%;
		left: 58%;
	}

	.point-us-01 {
		top: 66%;
		left: 34%;
	}

	.radar-point[data-state="online"] {
		opacity: 1;
		border-color: var(--hud-ink-strong);
	}

	.radar-point[data-state="offline"] {
		opacity: 0.28;
	}

	.monitor-summary {
		display: flex;
		flex-direction: column;
		gap: 0.45rem;
		min-width: 0;
	}

	.monitor-head {
		display: flex;
		justify-content: space-between;
		gap: 0.75rem;
		font-size: 0.7rem;
	}

	.monitor-label {
		color: var(--hud-line-strong);
	}

	.monitor-overall {
		text-align: right;
	}

	.monitor-subline {
		line-height: 1.7;
		color: var(--hud-line-strong);
	}

	.monitor-rows {
		display: flex;
		flex-direction: column;
	}

	.m-row {
		display: grid;
		grid-template-columns: 5.3rem 4.6rem minmax(0, 1fr) minmax(0, 1fr);
		gap: 0.65rem;
		align-items: center;
		padding: 0.55rem 0;
		border-bottom: 1px solid var(--hud-line);
	}

	.m-row[data-state="offline"] {
		color: var(--hud-line-strong);
	}

	.m-row[data-state="idle"] {
		color: var(--hud-line-strong);
	}

	.m-name,
	.m-state,
	.m-metric {
		white-space: nowrap;
	}

	@media (max-width: 640px) {
		.monitor-frame {
			grid-template-columns: 1fr;
		}

		.monitor-radar {
			width: 4.6rem;
			height: 4.6rem;
		}

		.m-row {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
	}
</style>
