---
const servers = [
	{ id: "hk-01", name: "HK-01" },
	{ id: "hk-02", name: "HK-02" },
	{ id: "us-01", name: "US-01" },
];
---

<div class="status-bar" data-cloud-monitor>
	<div class="status-head">
		<span class="status-prefix">SYS.MONITOR</span>
		<span class="status-divider">//</span>
		<span class="status-overall" data-monitor-overall-label>BOOTING</span>
	</div>

	<div class="status-nodes">
		{servers.map((server) => (
			<div class="status-node" data-server-id={server.id}>
				<span class="node-id">[{server.id.toUpperCase()}]</span>
				<span class="node-state" data-node-state>BOOT</span>
				<span class="node-metric node-metric-cpu">
					<span data-node-cores>--</span>C:<span data-node-cpu>--</span>%
				</span>
				<span class="node-metric node-metric-mem">
					<span data-node-ram>--</span>G:<span data-node-mem>--</span>%
				</span>
			</div>
		))}
	</div>
</div>

<script is:inline>
	const monitorRoot = document.querySelector("[data-cloud-monitor]");
	const overallLabel = monitorRoot?.querySelector("[data-monitor-overall-label]");
	const rows = new Map(
		Array.from(monitorRoot?.querySelectorAll("[data-server-id]") ?? []).map((row) => [
			row.getAttribute("data-server-id"),
			row,
		]),
	);

	const formatPercent = (value) => `${Math.round(value).toString().padStart(2, '0')}`;
	const formatHardwareCount = (value) => `${Math.max(1, Math.round(value))}`;
	const formatMemoryGb = (value) => {
		if (!Number.isFinite(value) || value <= 0) return "--";
		return value.toFixed(1).replace(/\.0$/, "");
	};

	const setOverallState = (label) => {
		if (overallLabel) overallLabel.textContent = label;
	};

	const setRowOffline = (row) => {
		const stateNode = row.querySelector("[data-node-state]");
		const cpuNode = row.querySelector("[data-node-cpu]");
		const memNode = row.querySelector("[data-node-mem]");
		const coreNode = row.querySelector("[data-node-cores]");
		const ramNode = row.querySelector("[data-node-ram]");
		if (stateNode) stateNode.textContent = "DOWN  ";
		if (cpuNode) cpuNode.textContent = "--";
		if (memNode) memNode.textContent = "--";
		if (coreNode) coreNode.textContent = "--";
		if (ramNode) ramNode.textContent = "--";
	};

	const updateRow = (server) => {
		const row = rows.get(server.id);
		if (!row) return;

		const isOnline = server.status === "online";
		const stateNode = row.querySelector("[data-node-state]");
		const cpuNode = row.querySelector("[data-node-cpu]");
		const memNode = row.querySelector("[data-node-mem]");
		const coreNode = row.querySelector("[data-node-cores]");
		const ramNode = row.querySelector("[data-node-ram]");

		if (!isOnline) {
			if (stateNode) stateNode.textContent = "DOWN  ";
			if (cpuNode) cpuNode.textContent = "--";
			if (memNode) memNode.textContent = "--";
			if (coreNode) coreNode.textContent = "--";
			if (ramNode) ramNode.textContent = "--";
			return;
		}

		const cpu = Number(server.metrics?.cpu ?? 0);
		const memory = Number(server.metrics?.memory ?? 0);
		const cpuCores = Number(server.hardware?.cpuCores ?? 0);
		const totalMemoryGb = Number(server.hardware?.totalMemoryGb ?? 0);
		const safeCpu = Number.isFinite(cpu) ? Math.max(0, Math.min(100, cpu)) : 0;
		const safeMemory = Number.isFinite(memory) ? Math.max(0, Math.min(100, memory)) : 0;

		if (stateNode) stateNode.textContent = "ONLINE";
		if (cpuNode) cpuNode.textContent = formatPercent(safeCpu);
		if (memNode) memNode.textContent = formatPercent(safeMemory);
		if (coreNode) coreNode.textContent = Number.isFinite(cpuCores) && cpuCores > 0 ? formatHardwareCount(cpuCores) : "--";
		if (ramNode) ramNode.textContent = formatMemoryGb(totalMemoryGb);
	};

	let nextPollTimer = null;

	const scheduleNextPoll = (intervalSeconds = 15) => {
		window.clearTimeout(nextPollTimer);
		nextPollTimer = window.setTimeout(fetchStatus, Math.max(5, intervalSeconds) * 1000);
	};

	async function fetchStatus() {
		setOverallState("FETCHING...");

		try {
			const response = await fetch("/api/server-status", {
				headers: { Accept: "application/json" },
				cache: "no-store",
			});
			if (!response.ok) {
				throw new Error(`Unexpected status: ${response.status}`);
			}

			const payload = await response.json();
			const responseServers = Array.isArray(payload.servers) ? payload.servers : [];
			const onlineCount = responseServers.filter((server) => server.status === "online").length;
			const totalCount = responseServers.length || rows.size;

			for (const server of responseServers) {
				updateRow(server);
			}

			for (const [serverId, row] of rows.entries()) {
				if (!responseServers.some((server) => server.id === serverId)) {
					setRowOffline(row);
				}
			}

			setOverallState(onlineCount === totalCount ? "ALL ONLINE" : `${onlineCount}/${totalCount} ONLINE`);
			scheduleNextPoll(payload.refreshIntervalSeconds ?? 15);
		} catch (error) {
			console.error("Failed to load server status", error);
			setOverallState("LINK LOST");
			for (const [, row] of rows.entries()) {
				setRowOffline(row);
			}
			scheduleNextPoll(15);
		}
	}

	if (monitorRoot) {
		fetchStatus();
	}
</script>

<style>
	.status-bar {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 1rem;
		font-family: var(--mono);
		font-size: 0.78rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--text-primary);
		text-shadow: var(--mono-shadow);
	}

	.status-head {
		display: flex;
		align-items: center;
		gap: 0.6rem;
		opacity: 0.95;
	}

	.status-nodes {
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 0.5rem;
	}

	.status-node {
		display: flex;
		gap: 0.58rem;
		opacity: 0.85;
		font-weight: 500;
	}
	
	.node-state {
		width: 4rem;
		text-align: left;
	}

	.node-metric {
		display: inline-block;
		white-space: nowrap;
		opacity: 0.82;
	}

	.node-metric-cpu {
		min-width: 5.8rem;
	}

	.node-metric-mem {
		min-width: 7.4rem;
	}

	@media (max-width: 720px) {
		.status-bar {
			flex-direction: column;
			align-items: flex-start;
			gap: 1rem;
			font-size: 0.72rem;
		}
		.status-nodes {
			align-items: flex-start;
		}

		.status-node {
			flex-wrap: wrap;
			row-gap: 0.2rem;
		}
	}
</style>
