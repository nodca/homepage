---
import CloudMonitor from "../components/CloudMonitor.astro";

const targets = [
	{ href: "https://blog.cyb1.org", label: "BLOG" },
	{ href: "https://s.cyb1.org", label: "TOOLS" },
	{ href: "https://huggingface.co/wcn123/Qwen3.5-27B-WebNovel-Writer-zh", label: "WRITER_MODEL" },
	{ href: "https://github.com/nodca/routellm", label: "ROUTE_LLM" },
	{ href: "http://38.76.207.72:3000", label: "GIT_SEARCH" },
	{ href: "https://github.com/nodca", label: "GITHUB" },
];
---

<html lang="zh-CN">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta
			name="description"
			content="nodca 的个人网站，记录开源项目、AI 模型、技术写作与正在构建的新东西。"
		/>
		<title>CYB1.ORG // NODCA</title>
	</head>
	<body>
		<video autoplay muted loop playsinline poster="/bg-poster.jpg" class="video-bg" data-nosnippet>
			<source src="/bg.mp4" type="video/mp4" />
		</video>
		<div class="overlay" aria-hidden="true"></div>

		<div class="vf-corner vf-tl" aria-hidden="true"></div>
		<div class="vf-corner vf-tr" aria-hidden="true"></div>
		<div class="vf-corner vf-bl" aria-hidden="true"></div>
		<div class="vf-corner vf-br" aria-hidden="true"></div>

		<div class="vf-center" aria-hidden="true">
			<span class="vf-center-h"></span>
			<span class="vf-center-v"></span>
			<span class="vf-center-box"></span>
		</div>

		<main class="hud-shell">
			<section class="hud-identity" aria-label="System identity">
				<div class="module-kicker">CYB1.ORG / NODCA</div>
				<h1>NODCA</h1>
				<p class="module-copy">
					[SYS_DESC] DEVELOPER, WRITER, AND BUILDER OF USEFUL INTERNET THINGS.
				</p>
				<p class="module-copy module-copy-zh">
					[FIELD_NOTE] 中文网文写作模型已经完成一版，现在把注意力切回新的实验、工具和更有意思的构建目标。
				</p>
				<div class="identity-meta">
					<span>PROFILE_01</span>
					<span>OBSERVER_MODE</span>
				</div>
			</section>

			<aside class="hud-monitor-slot" aria-label="Server journal">
				<div class="module-kicker module-kicker-right">SERVER JOURNAL</div>
				<CloudMonitor />
			</aside>

			<nav class="hud-targets" aria-label="External links">
				<div class="module-kicker">TARGETS</div>
				<div class="target-list">
					{
						targets.map((target, index) => (
							<a href={target.href} target="_blank" rel="noreferrer">
								<span class="target-cursor" aria-hidden="true">█</span>
								<span class="target-index">[{String(index + 1).padStart(2, "0")}]</span>
								<span class="target-name">{target.label}</span>
							</a>
						))
					}
				</div>
			</nav>

			<div class="hud-meta" aria-label="Viewfinder metadata">
				<p>REC // VIEWFINDER ONLINE</p>
				<p>CENTER FIELD RESERVED FOR BACKGROUND SUBJECT</p>
				<p>HUD / AR OVERLAY / STATIC FEED</p>
			</div>
		</main>
	</body>
</html>

<style is:global>
	@import url("https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap");

	:root {
		--hud-ink: rgba(18, 18, 18, 0.92);
		--hud-ink-strong: rgba(8, 8, 8, 0.98);
		--hud-line: rgba(18, 18, 18, 0.2);
		--hud-line-strong: rgba(18, 18, 18, 0.58);
		--hud-overlay: rgba(255, 255, 255, 0.14);
		--hud-pad: clamp(1.25rem, 3vw, 2.5rem);
		--corner-size: clamp(1.4rem, 2.2vw, 2.4rem);
		--frame-offset: clamp(1rem, 2.6vw, 2rem);
	}

	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	html {
		font-family: "JetBrains Mono", "SFMono-Regular", "Cascadia Code", "PingFang SC", monospace;
		background: #f3f0eb;
	}

	body {
		min-height: 100vh;
		color: var(--hud-ink);
		text-transform: uppercase;
		letter-spacing: 0.06em;
		position: relative;
		overflow: hidden;
	}

	a {
		color: inherit;
	}

	.video-bg {
		position: fixed;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
		z-index: -3;
	}

	.overlay {
		position: fixed;
		inset: 0;
		background: var(--hud-overlay);
		z-index: -2;
	}

	.vf-corner {
		position: fixed;
		width: var(--corner-size);
		height: var(--corner-size);
		border: 1px solid var(--hud-ink-strong);
		pointer-events: none;
		z-index: 5;
	}

	.vf-tl {
		top: var(--frame-offset);
		left: var(--frame-offset);
		border-right: 0;
		border-bottom: 0;
	}

	.vf-tr {
		top: var(--frame-offset);
		right: var(--frame-offset);
		border-left: 0;
		border-bottom: 0;
	}

	.vf-bl {
		bottom: var(--frame-offset);
		left: var(--frame-offset);
		border-right: 0;
		border-top: 0;
	}

	.vf-br {
		bottom: var(--frame-offset);
		right: var(--frame-offset);
		border-left: 0;
		border-top: 0;
	}

	.vf-center {
		position: fixed;
		inset: 50% auto auto 50%;
		width: 3.5rem;
		height: 3.5rem;
		transform: translate(-50%, -50%);
		pointer-events: none;
		z-index: 2;
	}

	.vf-center-h,
	.vf-center-v,
	.vf-center-box {
		position: absolute;
		display: block;
		background: var(--hud-line-strong);
	}

	.vf-center-h {
		top: 50%;
		left: 50%;
		width: 2rem;
		height: 1px;
		transform: translate(-50%, -50%);
	}

	.vf-center-v {
		top: 50%;
		left: 50%;
		width: 1px;
		height: 2rem;
		transform: translate(-50%, -50%);
	}

	.vf-center-box {
		inset: calc(50% - 0.4rem);
		width: 0.8rem;
		height: 0.8rem;
		border: 1px solid var(--hud-line);
		background: transparent;
	}

	.hud-shell {
		min-height: 100vh;
		padding: calc(var(--frame-offset) + 1rem);
		display: grid;
		grid-template-columns: minmax(16rem, 24rem) 1fr minmax(18rem, 25rem);
		grid-template-rows: auto 1fr auto;
		gap: clamp(1.5rem, 3vw, 3rem);
		position: relative;
		z-index: 4;
	}

	.hud-identity,
	.hud-monitor-slot,
	.hud-targets,
	.hud-meta {
		align-self: start;
	}

	.hud-identity {
		grid-column: 1;
		grid-row: 1;
		max-width: 24rem;
	}

	.hud-identity h1 {
		font-size: clamp(2.4rem, 5vw, 4rem);
		line-height: 0.9;
		margin: 1.2rem 0 1rem;
		font-weight: 700;
		letter-spacing: 0.08em;
	}

	.module-kicker {
		display: flex;
		align-items: center;
		gap: 0.85rem;
		font-size: 0.7rem;
		font-weight: 500;
		line-height: 1;
	}

	.module-kicker::after {
		content: "";
		flex: 1;
		height: 1px;
		background: var(--hud-line);
	}

	.module-kicker-right {
		justify-content: flex-end;
	}

	.module-kicker-right::after {
		display: none;
	}

	.module-kicker-right::before {
		content: "";
		flex: 1;
		height: 1px;
		background: var(--hud-line);
	}

	.module-copy {
		max-width: 24rem;
		font-size: 0.76rem;
		line-height: 1.8;
	}

	.module-copy + .module-copy {
		margin-top: 0.85rem;
	}

	.module-copy-zh {
		text-transform: none;
		letter-spacing: 0.03em;
	}

	.identity-meta {
		display: flex;
		flex-wrap: wrap;
		gap: 1rem;
		margin-top: 1.3rem;
		padding-top: 0.85rem;
		border-top: 1px solid var(--hud-line);
		font-size: 0.68rem;
	}

	.hud-monitor-slot {
		grid-column: 3;
		grid-row: 1;
		justify-self: end;
		width: min(100%, 25rem);
	}

	.hud-targets {
		grid-column: 1 / 3;
		grid-row: 3;
		align-self: end;
	}

	.target-list {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		column-gap: 1.25rem;
		row-gap: 0;
		margin-top: 1rem;
		max-width: 52rem;
	}

	.target-list a {
		display: grid;
		grid-template-columns: auto auto 1fr;
		align-items: center;
		gap: 0.75rem;
		padding: 0.85rem 0 0.8rem;
		border-top: 1px solid var(--hud-line);
		text-decoration: none;
		position: relative;
		transition: color 0.18s ease, padding-left 0.18s ease;
	}

	.target-list a::after {
		content: "";
		position: absolute;
		left: 0;
		bottom: 0;
		width: 0;
		height: 1px;
		background: var(--hud-ink-strong);
		transition: width 0.18s ease;
	}

	.target-list a:hover,
	.target-list a:focus-visible {
		color: var(--hud-ink-strong);
		padding-left: 0.55rem;
		outline: none;
	}

	.target-list a:hover::after,
	.target-list a:focus-visible::after {
		width: 100%;
	}

	.target-cursor {
		opacity: 0;
		transition: opacity 0.18s ease;
	}

	.target-list a:hover .target-cursor,
	.target-list a:focus-visible .target-cursor {
		opacity: 1;
	}

	.target-index {
		font-size: 0.72rem;
		color: var(--hud-line-strong);
	}

	.target-name {
		font-size: 0.82rem;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
	}

	.hud-meta {
		grid-column: 3;
		grid-row: 3;
		align-self: end;
		justify-self: end;
		text-align: right;
		font-size: 0.68rem;
		line-height: 1.8;
		padding-top: 0.85rem;
		border-top: 1px solid var(--hud-line);
		min-width: 18rem;
	}

	@media (max-width: 900px) {
		body {
			overflow: auto;
		}

		.hud-shell {
			grid-template-columns: 1fr;
			grid-template-rows: auto;
			padding: calc(var(--frame-offset) + 0.7rem);
		}

		.hud-identity,
		.hud-monitor-slot,
		.hud-targets,
		.hud-meta {
			grid-column: auto;
			grid-row: auto;
			width: 100%;
			max-width: none;
			justify-self: stretch;
		}

		.hud-monitor-slot {
			margin-top: 2rem;
		}

		.target-list {
			grid-template-columns: 1fr;
			max-width: none;
		}

		.hud-meta {
			text-align: left;
			min-width: 0;
			margin-top: 1rem;
		}

		.vf-center {
			display: none;
		}
	}

	@media (max-width: 640px) {
		.video-bg {
			display: none;
		}

		body {
			background:
				linear-gradient(rgba(255, 255, 255, 0.86), rgba(255, 255, 255, 0.86)),
				url("/bg-poster.jpg") center / cover no-repeat fixed;
		}

		.overlay {
			background: rgba(255, 255, 255, 0.08);
		}

		.vf-corner {
			width: 1rem;
			height: 1rem;
		}

		.hud-identity h1 {
			font-size: 2.1rem;
		}
	}
</style>
