---
import CloudMonitor from "../components/CloudMonitor.astro";

const targets = [
	{ href: "https://blog.cyb1.org", label: "Blog" },
	{ href: "https://s.cyb1.org", label: "Tools" },
	{ href: "https://huggingface.co/wcn123/Qwen3.5-27B-WebNovel-Writer-zh", label: "Writer Model" },
	{ href: "https://github.com/nodca/routellm", label: "RouteLLM" },
	{ href: "http://38.76.207.72:3000", label: "Git Search" },
	{ href: "https://github.com/nodca", label: "GitHub" },
];
---

<html lang="zh-CN">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta
			name="description"
			content="nodca 的个人网站，记录开源项目、AI 模型、技术写作与正在构建的新东西。"
		/>
		<title>CYB1.ORG // NODCA</title>
	</head>
	<body>
		<video autoplay muted loop playsinline poster="/bg-poster.jpg" class="video-bg" data-nosnippet>
			<source src="/bg.mp4" type="video/mp4" />
		</video>
		<div class="subtitle-fade" aria-hidden="true"></div>
		<div class="top-fade" aria-hidden="true"></div>

		<main class="vn-stage">
			<header class="status-shell" aria-label="Top status bar">
				<CloudMonitor />
			</header>

			<section class="subtitle-shell" aria-label="Profile subtitle">
				<p class="subtitle-kicker">CYB1.ORG</p>
				<h1 class="subtitle-title">nodca</h1>
				<p class="subtitle-line">Developer, writer, and builder of useful internet things.</p>
				<p class="subtitle-line subtitle-line-zh">
					中文网文写作模型已经做完一版，后续随缘优化，眼下去做新的东西。
				</p>
				<p class="subtitle-note">A personal log of tools, models, writing, and whatever comes next.</p>
			</section>

			<nav class="edge-nav" aria-label="External links">
				{
					targets.map((target) => (
						<a href={target.href} target="_blank" rel="noreferrer">
							<span class="nav-arrow" aria-hidden="true">→</span>
							<span class="nav-label">{target.label}</span>
						</a>
					))
				}
			</nav>
		</main>
	</body>
</html>

<style is:global>
	@import url("https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&family=JetBrains+Mono:wght@400;500&family=Noto+Serif+SC:wght@400;500;600&display=swap");

	:root {
		--text-primary: rgba(255, 250, 244, 0.98);
		--text-secondary: rgba(255, 250, 244, 0.85);
		--text-muted: rgba(255, 250, 244, 0.75);
		--serif-display: "Cormorant Garamond", "Noto Serif SC", "Source Han Serif SC", serif;
		--serif-body: "Noto Serif SC", "Source Han Serif SC", "Songti SC", serif;
		--mono: "JetBrains Mono", "SFMono-Regular", "Cascadia Mono", monospace;
		--subtitle-shadow: 0 2px 15px rgba(0, 0, 0, 0.45), 0 0 40px rgba(0, 0, 0, 0.3);
		--mono-shadow: 0 1px 8px rgba(0, 0, 0, 0.7), 0 0 20px rgba(0, 0, 0, 0.5);
	}

	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	html {
		background: #050505;
	}

	body {
		min-height: 100vh;
		color: var(--text-primary);
		position: relative;
		overflow: hidden;
		background: #050505;
		isolation: isolate;
	}

	a {
		color: inherit;
	}

	.video-bg {
		position: fixed;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		object-position: center;
		pointer-events: none;
		z-index: 0;
	}

	.top-fade {
		position: fixed;
		inset: 0 0 auto 0;
		height: 12rem;
		background: linear-gradient(to bottom, rgba(0, 0, 0, 0.5) 0%, rgba(0, 0, 0, 0.15) 40%, rgba(0, 0, 0, 0) 100%);
		pointer-events: none;
		z-index: 1;
	}

	.subtitle-fade {
		position: fixed;
		inset: auto 0 0 0;
		height: min(42vh, 24rem);
		background: linear-gradient(to top, rgba(0, 0, 0, 0.45) 0%, rgba(0, 0, 0, 0.2) 36%, rgba(0, 0, 0, 0) 82%);
		pointer-events: none;
		z-index: 1;
	}

	.vn-stage {
		min-height: 100vh;
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		grid-template-rows: auto 1fr auto;
		gap: clamp(1rem, 2vw, 2rem);
		padding: clamp(1.2rem, 2.5vw, 2rem) clamp(1.5rem, 3.5vw, 3rem) clamp(2rem, 4vw, 3.5rem);
		position: relative;
		z-index: 2;
	}

	.status-shell {
		grid-column: 1 / -1;
		grid-row: 1;
	}

	.subtitle-shell {
		grid-column: 1;
		grid-row: 3;
		align-self: end;
		max-width: min(54rem, 70vw);
		padding-right: 2rem;
	}

	.subtitle-kicker {
		font-family: var(--mono);
		font-size: 0.78rem;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: var(--text-secondary);
		text-shadow: var(--mono-shadow);
		margin-bottom: 1rem;
		font-weight: 500;
	}

	.subtitle-title {
		font-family: var(--serif-display);
		font-size: clamp(3.4rem, 9vw, 7rem);
		line-height: 0.84;
		font-weight: 600;
		letter-spacing: 0.03em;
		text-transform: none;
		text-shadow: var(--subtitle-shadow);
		margin-bottom: 0.9rem;
	}

	.subtitle-line {
		font-family: var(--serif-body);
		font-size: clamp(1.05rem, 1.7vw, 1.35rem);
		line-height: 1.9;
		letter-spacing: 0.03em;
		text-transform: none;
		color: var(--text-primary);
		text-shadow: var(--subtitle-shadow);
	}

	.subtitle-line-zh {
		color: var(--text-secondary);
	}

	.subtitle-note {
		margin-top: 1.25rem;
		font-family: var(--mono);
		font-size: 0.74rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: var(--text-muted);
		text-shadow: var(--mono-shadow);
	}

	.edge-nav {
		grid-column: 2;
		grid-row: 3;
		align-self: end;
		justify-self: end;
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 0.6rem;
		min-width: 14rem;
		padding-bottom: 0.2rem;
	}

	.edge-nav a {
		display: inline-flex;
		align-items: center;
		justify-content: flex-end;
		gap: 0.6rem;
		font-family: var(--mono);
		font-size: 1rem;
		letter-spacing: 0.18em;
		text-transform: uppercase;
		text-decoration: none;
		color: var(--text-primary);
		text-shadow: var(--mono-shadow);
		opacity: 0.85;
		font-weight: 500;
		transition: opacity 0.18s ease, color 0.18s ease, text-shadow 0.18s ease;
	}

	.edge-nav a:hover,
	.edge-nav a:focus-visible {
		color: #fff;
		opacity: 1;
		text-shadow: 0 2px 10px rgba(255, 255, 255, 0.4), 0 0 20px rgba(0, 0, 0, 0.8);
		outline: none;
	}

	.nav-arrow {
		opacity: 0;
		transition: opacity 0.18s ease;
	}

	.edge-nav a:hover .nav-arrow,
	.edge-nav a:focus-visible .nav-arrow {
		opacity: 1;
	}

	.nav-label {
		text-align: right;
	}

	@media (max-width: 900px) {
		body {
			overflow: auto;
		}

		.vn-stage {
			grid-template-columns: 1fr;
			grid-template-rows: auto 1fr auto auto;
			padding-bottom: 2rem;
		}

		.subtitle-shell,
		.edge-nav {
			grid-column: 1;
			justify-self: start;
			max-width: none;
			padding-right: 0;
		}

		.edge-nav {
			grid-row: 4;
			align-items: flex-start;
			margin-top: 0.8rem;
			min-width: 0;
		}

		.edge-nav a {
			justify-content: flex-start;
		}

		.nav-label {
			text-align: left;
		}
	}

	@media (max-width: 768px) {
		.vn-stage {
			min-height: 100svh;
			grid-template-rows: auto 1fr auto auto;
			gap: clamp(0.65rem, 3vw, 1rem);
			padding:
				calc(0.9rem + env(safe-area-inset-top, 0px))
				clamp(1rem, 4vw, 1.35rem)
				calc(1.35rem + env(safe-area-inset-bottom, 0px));
		}

		.status-shell {
			max-width: min(14rem, calc(100vw - 2rem));
		}

		.subtitle-fade {
			height: 50vh;
			background:
				linear-gradient(
					to top,
					rgba(0, 0, 0, 0.74) 0%,
					rgba(0, 0, 0, 0.52) 34%,
					rgba(0, 0, 0, 0.14) 78%,
					rgba(0, 0, 0, 0) 100%
				);
		}

		.subtitle-shell {
			grid-row: 3;
			align-self: end;
			max-width: min(24rem, 100%);
		}

		.subtitle-kicker {
			font-size: 0.72rem;
			margin-bottom: 0.8rem;
			letter-spacing: 0.2em;
		}

		.subtitle-title {
			font-size: clamp(3.2rem, 15vw, 3.8rem);
			margin-bottom: 0.75rem;
		}

		.subtitle-line {
			font-size: 0.96rem;
			line-height: 1.72;
		}

		.subtitle-note {
			max-width: 20rem;
			margin-top: 1rem;
			font-size: 0.68rem;
			letter-spacing: 0.11em;
		}

		.edge-nav {
			display: grid;
			grid-template-columns: repeat(2, minmax(0, max-content));
			gap: 0.55rem 1rem;
			align-items: start;
			justify-content: start;
			width: fit-content;
			max-width: min(22rem, 100%);
			margin-top: 0.95rem;
			padding-bottom: 0;
		}

		.edge-nav a {
			gap: 0.35rem;
			font-size: 0.84rem;
			letter-spacing: 0.14em;
			opacity: 0.92;
		}

		.nav-arrow {
			display: none;
		}
	}

	@media (max-width: 640px) {
		body {
			background:
				linear-gradient(rgba(8, 8, 8, 0.26), rgba(8, 8, 8, 0.18)),
				url("/bg-poster.jpg") center / cover no-repeat fixed;
		}

		.subtitle-line {
			font-size: 0.92rem;
			line-height: 1.68;
		}

		.edge-nav {
			gap: 0.45rem 0.85rem;
		}

		.edge-nav a {
			font-size: 0.78rem;
		}
	}

	@media (max-width: 420px) {
		.subtitle-title {
			font-size: clamp(3rem, 16vw, 3.45rem);
		}

		.edge-nav {
			grid-template-columns: repeat(2, minmax(0, 1fr));
			width: 100%;
		}

		.edge-nav a {
			min-width: 0;
		}

		.nav-label {
			overflow-wrap: anywhere;
		}
	}
</style>
