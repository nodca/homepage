---
import CloudMonitor from "../components/CloudMonitor.astro";
---

<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="nodca 的个人网站，记录开源项目、AI 模型、技术写作与正在构建的新东西。" />
    <title>cyb1.org - nodca 的个人网站</title>
  </head>
  <body>
    <video autoplay muted loop playsinline poster="/bg-poster.jpg" class="video-bg" data-nosnippet>
      <source src="/bg.mp4" type="video/mp4" />
    </video>
    <div class="overlay"></div>

    <main>
      <section class="hero">
        <div class="hero-shell glass-panel">
          <p class="hero-kicker">CYB1.ORG</p>
          <div class="hero-heading">
            <div class="avatar">
              <span>N</span>
            </div>
            <div class="hero-copy">
              <h1>nodca</h1>
              <p class="hero-tagline">Developer, writer, and builder of useful internet things.</p>
            </div>
          </div>
          <p class="hero-summary">中文网文写作模型已经做完一版，后续随缘优化，眼下去做新的东西。</p>
          <div class="social-links">
            <a href="https://github.com/nodca" target="_blank" rel="noreferrer" aria-label="GitHub">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-github"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
            </a>
          </div>
        </div>
      </section>

      <CloudMonitor />

      <section class="projects" aria-labelledby="projects-title">
        <div class="section-heading">
          <p class="section-kicker">Selected Links</p>
          <h2 id="projects-title">Projects</h2>
        </div>

        <div class="cards">
          <a href="https://blog.cyb1.org" class="card glass-panel" target="_blank" rel="noreferrer">
            <div class="icon-wrapper">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-pen-line"><path d="M12 20h9"/><path d="M16.376 3.622a1 1 0 0 1 3.002 3.002L7.368 18.635a2 2 0 0 1-.855.506l-2.872.838a.5.5 0 0 1-.62-.62l.838-2.872a2 2 0 0 1 .506-.854z"/><path d="m15 5 3 3"/></svg>
            </div>
            <div class="card-content">
              <h2>博客</h2>
              <p>记录生活与技术</p>
            </div>
          </a>

          <a href="https://s.cyb1.org" class="card glass-panel" target="_blank" rel="noreferrer">
            <div class="icon-wrapper">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-link"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            </div>
            <div class="card-content">
              <h2>短链工具</h2>
              <p>快速生成短链接</p>
            </div>
          </a>

          <a href="https://huggingface.co/wcn123/Qwen3.5-27B-WebNovel-Writer-zh" class="card glass-panel" target="_blank" rel="noreferrer">
            <span class="card-badge" aria-label="Hugging Face" title="Hugging Face">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <circle cx="12" cy="12" r="9"></circle>
                <path d="M8 14c1.2 1 2.5 1.5 4 1.5s2.8-.5 4-1.5"></path>
                <path d="M9 10h.01"></path>
                <path d="M15 10h.01"></path>
              </svg>
              <span>HF</span>
            </span>
            <div class="icon-wrapper">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-box"><path d="M21 8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16Z"/><path d="m3.3 7 8.7 5 8.7-5"/><path d="M12 22V12"/></svg>
            </div>
            <div class="card-content">
              <h2>Writer Model</h2>
              <p>中文网文写作微调模型</p>
            </div>
          </a>

          <a href="https://github.com/nodca/routellm" class="card glass-panel" target="_blank" rel="noreferrer">
            <span class="card-badge github-badge" aria-label="GitHub" title="GitHub">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
                <path d="M9 18c-4.51 2-5-2-7-2"/>
              </svg>
              <span>GH</span>
            </span>
            <div class="icon-wrapper">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-waypoints"><circle cx="12" cy="4.5" r="2.5"/><path d="m10.2 6.3-3.9 6.4"/><circle cx="4.5" cy="14" r="2.5"/><path d="m7 14h10.5"/><circle cx="19.5" cy="14" r="2.5"/><path d="m13.8 6.3 3.9 6.4"/><path d="M12 7v10.5"/><circle cx="12" cy="19.5" r="2.5"/></svg>
            </div>
            <div class="card-content">
              <h2>RouteLLM</h2>
              <p>轻量 LLM 路由网关</p>
            </div>
          </a>

          <a href="http://38.76.207.72:3000" class="card glass-panel" target="_blank" rel="noreferrer">
            <div class="icon-wrapper">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-git-branch"><line x1="6" x2="6" y1="3" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/></svg>
            </div>
            <div class="card-content">
              <h2>GitSearch</h2>
              <p>GitHub 热门项目情报中心</p>
            </div>
          </a>
        </div>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    --panel-bg: rgba(255, 255, 255, 0.78);
    --panel-bg-strong: rgba(255, 255, 255, 0.88);
    --panel-border: rgba(92, 77, 55, 0.12);
    --panel-border-strong: rgba(92, 77, 55, 0.2);
    --text-main: #3f3327;
    --text-muted: rgba(63, 51, 39, 0.74);
    --text-soft: rgba(63, 51, 39, 0.58);
    --page-tint: rgba(255, 249, 240, 0.92);
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    font-family: "Avenir Next", "Hiragino Sans GB", "PingFang SC", "Microsoft YaHei", sans-serif;
    scroll-behavior: smooth;
    background: #f7efe2;
  }

  body {
    min-height: 100vh;
    padding: clamp(28px, 5vw, 72px) clamp(18px, 5vw, 72px) clamp(56px, 8vw, 96px);
    overflow-x: hidden;
    color: var(--text-main);
    line-height: 1.6;
  }

  .video-bg {
    position: fixed;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: -2;
    object-fit: cover;
    object-position: center;
  }

  .overlay {
    position: fixed;
    inset: 0;
    z-index: -1;
    background:
      linear-gradient(90deg, var(--page-tint) 0%, rgba(255, 249, 240, 0.82) 26%, rgba(255, 249, 240, 0.52) 50%, rgba(255, 249, 240, 0.2) 74%, rgba(255, 249, 240, 0.08) 100%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.28), rgba(255, 255, 255, 0.06));
  }

  main {
    position: relative;
    width: min(100%, 1040px);
    display: flex;
    flex-direction: column;
    gap: clamp(1.75rem, 4vw, 3rem);
  }

  .glass-panel {
    background: var(--panel-bg);
    border: 1px solid var(--panel-border);
    border-radius: 8px;
    transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease, opacity 0.2s ease;
  }

  .hero {
    max-width: 46rem;
  }

  .hero-shell {
    padding: clamp(1.8rem, 4vw, 3rem);
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .hero-kicker,
  .section-kicker {
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-soft);
  }

  .hero-heading {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem 1.3rem;
    align-items: center;
  }

  .avatar {
    width: 4.5rem;
    height: 4.5rem;
    border-radius: 8px;
    border: 1px solid var(--panel-border);
    background: rgba(255, 255, 255, 0.84);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: "Iowan Old Style", "Palatino Linotype", "Noto Serif SC", "Source Han Serif SC", serif;
    font-size: 2rem;
    color: var(--text-main);
  }

  .hero-copy h1,
  .section-heading h2 {
    font-family: "Iowan Old Style", "Palatino Linotype", "Noto Serif SC", "Source Han Serif SC", serif;
    color: var(--text-main);
  }

  .hero-copy h1 {
    font-size: clamp(2.8rem, 8vw, 4.8rem);
    line-height: 0.94;
    letter-spacing: -0.05em;
    font-weight: 600;
    margin-bottom: 0.45rem;
  }

  .hero-tagline {
    max-width: 28rem;
    font-size: 1rem;
    color: var(--text-muted);
  }

  .hero-summary {
    max-width: 34rem;
    font-size: 1rem;
    color: var(--text-main);
  }

  .social-links {
    display: flex;
    gap: 0.8rem;
  }

  .social-links a {
    width: 2.75rem;
    height: 2.75rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    border: 1px solid var(--panel-border);
    border-radius: 6px;
    background: rgba(255, 255, 255, 0.52);
    transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease, opacity 0.2s ease;
  }

  .social-links a:hover {
    background: rgba(255, 255, 255, 0.84);
    border-color: var(--panel-border-strong);
    color: var(--text-main);
  }

  .projects {
    width: 100%;
  }

  .section-heading {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin-bottom: 1rem;
    padding-left: 0.15rem;
  }

  .section-heading h2 {
    font-size: clamp(1.9rem, 3vw, 2.5rem);
    line-height: 1;
    letter-spacing: -0.04em;
    font-weight: 600;
  }

  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1rem;
  }

  .card {
    min-height: 13rem;
    padding: clamp(1.4rem, 3vw, 2rem);
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 2.4rem;
    position: relative;
  }

  .card:hover {
    background: var(--panel-bg-strong);
    border-color: var(--panel-border-strong);
  }

  .card-badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.28rem 0.5rem;
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.72);
    border: 1px solid var(--panel-border);
    color: var(--text-soft);
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .card-badge svg {
    width: 12px;
    height: 12px;
  }

  .github-badge {
    background: rgba(255, 255, 255, 0.8);
  }

  .icon-wrapper {
    width: 3rem;
    height: 3rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--text-main);
    opacity: 0.8;
    border-radius: 6px;
    border: 1px solid rgba(92, 77, 55, 0.1);
    background: rgba(255, 255, 255, 0.56);
    transition: background-color 0.2s ease, border-color 0.2s ease, color 0.2s ease, opacity 0.2s ease;
  }

  .card:hover .icon-wrapper {
    background: rgba(255, 255, 255, 0.86);
    border-color: var(--panel-border-strong);
    opacity: 1;
  }

  .card-content {
    max-width: 17rem;
  }

  .card-content h2 {
    font-family: "Iowan Old Style", "Palatino Linotype", "Noto Serif SC", "Source Han Serif SC", serif;
    font-size: 1.22rem;
    line-height: 1.1;
    font-weight: 600;
    letter-spacing: -0.03em;
    margin-bottom: 0.45rem;
    color: var(--text-main);
  }

  .card-content p {
    font-size: 0.92rem;
    line-height: 1.6;
    color: var(--text-muted);
  }

  @media (max-width: 720px) {
    .hero-heading {
      grid-template-columns: 1fr;
      align-items: flex-start;
    }

    .avatar {
      width: 3.8rem;
      height: 3.8rem;
      font-size: 1.7rem;
    }

    .cards {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    body {
      background-image: url("/7e147c4752fffd6dae0d32c1270de578.webp");
      background-size: cover;
      background-position: center;
      background-attachment: scroll;
    }

    .video-bg {
      display: none;
    }

    .overlay {
      background:
        linear-gradient(180deg, rgba(255, 249, 240, 0.88), rgba(255, 249, 240, 0.6)),
        linear-gradient(90deg, rgba(255, 249, 240, 0.8), rgba(255, 249, 240, 0.18));
    }

    .hero-shell,
    .card {
      padding: 1.35rem;
    }

    .card-badge {
      top: 0.8rem;
      right: 0.8rem;
    }
  }
</style>
