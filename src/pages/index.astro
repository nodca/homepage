		</main>

		<script>
			const texts = [
				"Developer & Creator.",
				"Open Source Builder.",
				"Shipped a Long-form Story Model.",
				"Building tools that matter.",
				"Now building the next thing.",
				"Welcome to cyb1.org."
			];
			const speed = 100; // 打字速度
			const pause = 2000; // 句子之间的停顿
			const textElement = document.querySelector(".typewriter-text");
			let textIndex = 0;
			let charIndex = 0;
			let isDeleting = false;

			function type() {
				const currentText = texts[textIndex];

				if (isDeleting) {
					textElement.textContent = currentText.substring(0, charIndex - 1);
					charIndex--;
				} else {
					textElement.textContent = currentText.substring(0, charIndex + 1);
					charIndex++;
				}

				let typeSpeed = speed;

				if (isDeleting) {
					typeSpeed /= 2; // 删除速度快一倍
				}

				if (!isDeleting && charIndex === currentText.length) {
					typeSpeed = pause;
					isDeleting = true;
				} else if (isDeleting && charIndex === 0) {
					isDeleting = false;
					textIndex = (textIndex + 1) % texts.length;
					typeSpeed = 500; // 开始下一个句子前的停顿
				}

				setTimeout(type, typeSpeed);
			}

			// 启动打字机效果
			setTimeout(type, 1000);
		</script>
	</body>
</html>

<style>
	:root {
		--glass-bg: rgba(20, 20, 20, 0.4); /* 更深的底色，增加与纯白文字的对比，透出视频 */
		--glass-border: rgba(255, 255, 255, 0.08); /* 极细极暗的边框，保持克制 */
		--glass-hover-bg: rgba(40, 40, 40, 0.6); /* 悬浮时稍亮，更有实体感 */
		--glass-hover-border: rgba(255, 255, 255, 0.2); /* 悬浮时边框稍亮 */
		--text-main: rgba(255, 255, 255, 0.95);
		--text-muted: rgba(255, 255, 255, 0.6);
		--accent-color: #fceea7; /* 呼应 Lemon Girl 的淡黄色 */
	}

	* {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	html {
		font-family: "Inter", system-ui, -apple-system, "Segoe UI", Roboto, "PingFang SC", "Microsoft YaHei", sans-serif;
		scroll-behavior: smooth;
	}

	body {
		min-height: 100vh;
		display: flex;
		align-items: flex-start; /* 改为从顶部开始，方便向下滚动 */
		justify-content: center;
		padding: 60px 20px;
		overflow-x: hidden;
		color: var(--text-main);
	}

	.video-bg {
		position: fixed;
		top: 50%;
		left: 50%;
		min-width: 100%;
		min-height: 100%;
		width: auto;
		height: auto;
		transform: translate(-50%, -50%);
		z-index: -2;
		object-fit: cover;
	}

	.overlay {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: radial-gradient(circle at center, rgba(0, 0, 0, 0.2) 0%, rgba(0, 0, 0, 0.6) 100%); /* 渐变遮罩，四周暗，中间稍亮 */
		z-index: -1;
	}

	main {
		z-index: 1;
		width: 100%;
		max-width: 800px;
		display: flex;
		flex-direction: column;
		gap: 3rem; /* 各个 section 之间的间距 */
	}

	/* --- 通用毛玻璃面板样式 --- */
	.glass-panel {
		background: var(--glass-bg);
		backdrop-filter: blur(16px);
		-webkit-backdrop-filter: blur(16px);
		border: 1px solid var(--glass-border);
		border-radius: 20px;
		transition: all 0.3s ease;
	}

	/* --- Hero Section (个人信息) --- */
	.hero {
		text-align: center;
		display: flex;
		flex-direction: column;
		align-items: center;
		animation: fadeInDown 1s ease-out;
	}

	.avatar {
		width: 90px;
		height: 90px;
		border-radius: 50%;
		background: linear-gradient(135deg, rgba(255,255,255,0.1), rgba(255,255,255,0.02));
		backdrop-filter: blur(10px);
		border: 1px solid var(--glass-border);
		display: flex;
		align-items: center;
		justify-content: center;
		font-size: 2.5rem;
		font-weight: 300;
		color: var(--text-main);
		margin-bottom: 1.5rem;
		box-shadow: 0 8px 32px rgba(0, 0, 0, 0.2);
	}

	.hero h1 {
		font-size: 3rem;
		font-weight: 700;
		letter-spacing: -1px;
		margin-bottom: 0.5rem;
		text-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
	}

	.typewriter-container {
		font-size: 1.1rem;
		color: var(--text-muted);
		height: 1.5rem; /* 固定高度防止抖动 */
		margin-bottom: 1.5rem;
		font-weight: 300;
		letter-spacing: 0.5px;
	}

	.cursor {
		display: inline-block;
		width: 2px;
		animation: blink 1s step-end infinite;
		color: var(--accent-color);
		margin-left: 2px;
	}

	@keyframes blink {
		0%, 100% { opacity: 1; }
		50% { opacity: 0; }
	}

	.social-links {
		display: flex;
		gap: 1.5rem;
	}

	.social-links a {
		color: var(--text-muted);
		transition: all 0.3s ease;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0.5rem;
		border-radius: 50%;
	}

	.social-links a:hover {
		color: var(--text-main);
		transform: translateY(-3px);
		background: rgba(255, 255, 255, 0.05);
	}

	/* --- Status Section (动态卡片) --- */
	.status-section {
		animation: fadeInUp 1s ease-out 0.2s both;
	}

	.status-card {
		padding: 1rem 1.5rem;
		display: flex;
		align-items: center;
		gap: 1rem;
		font-size: 0.95rem;
		color: var(--text-main);
		font-weight: 300;
	}

	.status-dot {
		width: 8px;
		height: 8px;
		background-color: var(--accent-color);
		border-radius: 50%;
		box-shadow: 0 0 10px var(--accent-color);
		animation: pulse 2s infinite;
		flex-shrink: 0;
	}

	@keyframes pulse {
		0% { box-shadow: 0 0 0 0 rgba(252, 238, 167, 0.4); }
		70% { box-shadow: 0 0 0 6px rgba(252, 238, 167, 0); }
		100% { box-shadow: 0 0 0 0 rgba(252, 238, 167, 0); }
	}

	/* --- Projects Section (卡片网格) --- */
	.projects {
		animation: fadeInUp 1s ease-out 0.4s both;
	}

	.cards {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
		gap: 1.5rem;
	}

	.card {
		padding: 1.8rem;
		text-decoration: none;
		color: inherit;
		display: flex;
		flex-direction: column;
		align-items: flex-start; /* 左对齐更显现代 */
		position: relative;
		overflow: hidden;
	}

	.card::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: linear-gradient(135deg, rgba(255,255,255,0.05) 0%, transparent 100%);
		opacity: 0;
		transition: opacity 0.4s ease;
	}

	.card:hover {
		transform: translateY(-6px);
		background: var(--glass-hover-bg);
		border-color: var(--glass-hover-border);
		box-shadow: 0 16px 32px rgba(0, 0, 0, 0.4), 0 0 20px rgba(255, 255, 255, 0.05) inset;
	}

	.card:hover::before {
		opacity: 1;
	}

	.card-badge {
		position: absolute;
		top: 1rem;
		right: 1rem;
		z-index: 1;
		display: inline-flex;
		align-items: center;
		gap: 0.35rem;
		padding: 0.3rem 0.55rem;
		border-radius: 999px;
		background: rgba(255, 184, 76, 0.14);
		border: 1px solid rgba(255, 184, 76, 0.3);
		backdrop-filter: blur(10px);
		-webkit-backdrop-filter: blur(10px);
		color: #ffd28a;
		font-size: 0.68rem;
		font-weight: 600;
		letter-spacing: 0.08em;
		text-transform: uppercase;
	}

	.card-badge svg {
		width: 12px;
		height: 12px;
	}

	.card:hover .card-badge {
		background: rgba(255, 184, 76, 0.2);
		border-color: rgba(255, 210, 138, 0.45);
	}

	.icon-wrapper {
		margin-bottom: 1.2rem;
		color: var(--text-main);
		opacity: 0.8;
		transition: all 0.3s ease;
		background: rgba(255, 255, 255, 0.05);
		padding: 12px;
		border-radius: 14px;
		border: 1px solid rgba(255, 255, 255, 0.05);
	}

	.card:hover .icon-wrapper {
		opacity: 1;
		transform: scale(1.1);
		color: var(--accent-color);
		border-color: rgba(252, 238, 167, 0.2);
	}

	.card-content h2 {
		font-size: 1.2rem;
		font-weight: 600;
		margin-bottom: 0.4rem;
		letter-spacing: -0.3px;
	}

	.card-content p {
		color: var(--text-muted);
		font-size: 0.85rem;
		line-height: 1.4;
		font-weight: 300;
	}

	/* --- Animations --- */
	@keyframes fadeInDown {
		from { opacity: 0; transform: translateY(-20px); }
		to { opacity: 1; transform: translateY(0); }
	}

	@keyframes fadeInUp {
		from { opacity: 0; transform: translateY(20px); }
		to { opacity: 1; transform: translateY(0); }
	}

	@media (max-width: 600px) {
		body { 
			padding: 40px 15px; 
			/* 手机端使用背景图，隐藏视频以解决比例和性能问题 */
			background-image: url('/7e147c4752fffd6dae0d32c1270de578.webp');
			background-size: cover;
			background-attachment: fixed;
		}
		
		/* 隐藏视频 */
		.video-bg {
			display: none;
		}

		.hero h1 { font-size: 2.5rem; }
		
		/* 手机端强制双列布局，减小间距 */
		.cards { 
			grid-template-columns: repeat(2, 1fr); 
			gap: 1rem;
		} 
		
		/* 缩小卡片内边距和内容，使其在双列下不拥挤 */
		.card { 
			padding: 1.2rem; 
		}

		.card-badge {
			top: 0.8rem;
			right: 0.8rem;
			padding: 0.24rem 0.45rem;
			font-size: 0.6rem;
		}

		.card-badge svg {
			width: 10px;
			height: 10px;
		}

		.icon-wrapper {
			padding: 8px;
			margin-bottom: 0.8rem;
		}

		.icon-wrapper svg {
			width: 20px;
			height: 20px;
		}

		.card-content h2 {
			font-size: 1rem;
		}

		.card-content p {
			font-size: 0.75rem;
		}
	}
</style>
